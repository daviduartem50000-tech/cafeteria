# Ambiente LOCAL (use estes nomes rodando na sua máquina com MySQL local)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=cafeteria
DB_PORT=3306

# Porta do servidor Express
PORT=3001

# No Railway, quando você adiciona o plugin de MySQL, ele cria
# automaticamente as variáveis MYSQLHOST, MYSQLUSER, MYSQLPASSWORD,
# MYSQLDATABASE e MYSQLPORT no serviço do backend — você não precisa
# copiá-las manualmente, o código já está preparado para usá-las.
